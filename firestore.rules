rules_version = '2';

// Nemo Aqua Store — Firestore security rules
// SHARED-STORE model: there is ONE business store at /stores/main.
// Both you and your co-admin work on the SAME data (orders, expenses, etc).
// Access is limited to an admin allowlist.
//
// Bootstrap admin (always allowed, hardcoded so you can never lock yourself out):
//   cI2HmMt6FdR7fO7uUnugH85GeZt2   <-- your Google UID
//
// Additional admins are listed in /stores/main/meta/config.admins (an array of
// UIDs). You add your co-admin's UID from inside the app (Settings), which writes
// to that doc. The rules read it live via get().

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // The one hardcoded super-admin (you). Replace/extend only by editing here.
    function isBootstrapAdmin() {
      return signedIn() && request.auth.uid == 'cI2HmMt6FdR7fO7uUnugH85GeZt2';
    }

    // Admins listed in the config doc (added from the app by an existing admin).
    function configAdmins() {
      return get(/databases/$(database)/documents/stores/main/meta/config).data.admins;
    }
    function isListedAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/stores/main/meta/config)
        && (request.auth.uid in configAdmins());
    }

    function isAdmin() {
      return isBootstrapAdmin() || isListedAdmin();
    }

    // All business data lives under /stores/main/** — admins only.
    match /stores/main/{document=**} {
      allow read, write: if isAdmin();
    }

    // Everything else is denied by default.
  }
}
