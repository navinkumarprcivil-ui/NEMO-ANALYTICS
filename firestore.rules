rules_version = '2';

// Nemo Aqua Store — Firestore security rules
// SHARED-STORE model: ONE business store at /stores/main.
// You and your co-admins all work on the SAME data. Access is allowlisted.
//
// Owner (always allowed — matched by EMAIL or UID, never lockable-out):
//   nemoaquastore@gmail.com
//   aDMlthwXO9bExE0UDyCmdWBU8cQ2
//
// Extra admins live in /stores/main/meta/config.admins (array of UIDs),
// added from inside the app (Settings) by the owner.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // The permanent owner — by email OR uid.
    function isOwner() {
      return signedIn() && (
        request.auth.token.email == 'nemoaquastore@gmail.com'
        || request.auth.uid == 'aDMlthwXO9bExE0UDyCmdWBU8cQ2'
      );
    }

    function configAdmins() {
      return get(/databases/$(database)/documents/stores/main/meta/config).data.admins;
    }
    function isListedAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/stores/main/meta/config)
        && (request.auth.uid in configAdmins());
    }

    function isAdmin() {
      return isOwner() || isListedAdmin();
    }

    match /stores/main/{document=**} {
      allow read, write: if isAdmin();
    }

    // Everything else denied by default.
  }
}
